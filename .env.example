# 앱용 등록 시트 (필수) - 사용자 tenantId ↔ 사용자 시트 ID 매핑용. 구글 시트 1개 만들고 서비스 계정에 편집자 공유 후 ID 넣기.
# 시트 URL에서 /d/ 다음 부분이 ID 예: https://docs.google.com/spreadsheets/d/여기가ID/edit
REGISTRY_SHEET_ID=your_registry_sheet_id

# 구글 스프레드시트 연동 (서비스 계정)
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...@....iam.gserviceaccount.com",...}
